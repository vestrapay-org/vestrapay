APP_NAME=VestraPay
APP_ENV=local
APP_LANGUAGE=en
APP_TIMEZONE=Asia/Jakarta

HOME_URL=https://vestrapay.io
HOME_NAME=VestraPay

HTTP_HOST=0.0.0.0
HTTP_PORT=3000

LOGGER_ENABLE=true
LOGGER_LEVEL=debug
LOGGER_INTO_FILE=true
LOGGER_PRETTIER=true
LOGGER_AUTO=false

CORS_ALLOWED_ORIGIN=*

URL_VERSIONING_ENABLE=true
URL_VERSION=1

DATABASE_URL=postgresql://vestrapay:vestrapay@localhost:5432/vestrapay
DATABASE_DEBUG=true

AUTH_JWT_ISSUER=https://vestrapay.io
AUTH_JWT_AUDIENCE=VestraPay

AUTH_JWT_ACCESS_TOKEN_JWKS_URI=http://localhost:3011/.well-known/access-jwks.json
AUTH_JWT_ACCESS_TOKEN_KID=vestrapay-access-2024-001
AUTH_JWT_ACCESS_TOKEN_PRIVATE_KEY=qwerty1234567890
AUTH_JWT_ACCESS_TOKEN_PUBLIC_KEY=qwerty1234567890
AUTH_JWT_ACCESS_TOKEN_EXPIRED=1h

AUTH_JWT_REFRESH_TOKEN_JWKS_URI=http://localhost:3011/.well-known/refresh-jwks.json
AUTH_JWT_REFRESH_TOKEN_KID=vestrapay-refresh-2024-001
AUTH_JWT_REFRESH_TOKEN_PRIVATE_KEY=qwerty1234567890
AUTH_JWT_REFRESH_TOKEN_PUBLIC_KEY=qwerty1234567890
AUTH_JWT_REFRESH_TOKEN_EXPIRED=30d

AUTH_TWO_FACTOR_ISSUER=VestraPayTwoFactor
AUTH_TWO_FACTOR_ENCRYPTION_KEY=qwerty1234567890

AWS_S3_IAM_CREDENTIAL_KEY=
AWS_S3_IAM_CREDENTIAL_SECRET=
AWS_S3_IAM_ARN=
AWS_S3_REGION=ap-southeast-3
AWS_S3_PUBLIC_BUCKET=
AWS_S3_PUBLIC_CDN=
AWS_S3_PRIVATE_BUCKET=
AWS_S3_PRIVATE_CDN=

AWS_SES_IAM_CREDENTIAL_KEY=
AWS_SES_IAM_CREDENTIAL_SECRET=
AWS_SES_IAM_ARN=
AWS_SES_REGION=ap-southeast-3

CACHE_REDIS_URL=redis://localhost:6379/0

QUEUE_REDIS_URL=redis://localhost:6379/1

SENTRY_DSN=

# ─── Payment Processors ─────────────────────────────────────────────────────

# MPGS (Mastercard Payment Gateway)
MPGS_BASE_URL=https://test-gateway.mastercard.com/api/rest/version/82
MPGS_MERCHANT_ID=
MPGS_API_PASSWORD=
MPGS_VERSION=82

# AlatPay (Wema Bank - Transfer & USSD)
ALATPAY_BASE_URL=https://apibox.alatpay.ng
ALATPAY_SECRET_KEY=
ALATPAY_BUSINESS_ID=

# Payment Fees (amounts in kobo, percentages as decimals)
PAYMENT_FEE_CARD_PERCENTAGE=4.3
PAYMENT_FEE_TRANSFER_INFLOW_PERCENTAGE=1.4
PAYMENT_FEE_TRANSFER_INFLOW_CAP=200000
PAYMENT_FEE_TRANSFER_OUTFLOW_FLAT=5000

# Transaction Settings
PAYMENT_TRANSACTION_TIMEOUT_MINUTES=30
PAYMENT_REFERENCE_PREFIX=VPY
