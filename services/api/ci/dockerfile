# ── Base ──────────────────────────────────────────────────────────
FROM node:24-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.26.2 --activate

# ── Dependencies ──────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml .npmrc package.json ./
COPY services/api/package.json ./services/api/package.json
RUN --mount=type=cache,id=s/86e691c5-8215-479a-9543-f608c49b5775-pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile --filter=@vestrapay/api

# ── Builder (also used by migrator + seeder via docker-compose) ──
FROM deps AS builder
COPY ./services/api ./services/api
WORKDIR /app/services/api
RUN --mount=type=cache,id=s/86e691c5-8215-479a-9543-f608c49b5775-pnpm,target=/pnpm/store \
    pnpm db:generate
RUN pnpm build
RUN pnpm deploy --legacy --filter=@vestrapay/api --prod /app/deployed

# ── Runtime ───────────────────────────────────────────────────────
FROM base AS runtime
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/deployed/node_modules ./node_modules
COPY --from=builder /app/services/api/dist ./dist
COPY --from=builder /app/services/api/generated/prisma-client ./generated/prisma-client
COPY --from=builder /app/services/api/prisma ./prisma
COPY --from=builder /app/services/api/package.json ./package.json
COPY services/api/ci/entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

RUN addgroup -S appuser && adduser -S appuser -G appuser && \
    chown -R appuser:appuser /app
USER appuser
EXPOSE 3000

CMD ["node", "dist/main"]
